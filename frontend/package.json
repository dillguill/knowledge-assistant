    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^9.0.0",
    "katex": "^0.18.1",
    "lucide-react": "^1.24.0",
    "mermaid": "^11.16.0",
    "parse-diff": "^0.12.0",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
